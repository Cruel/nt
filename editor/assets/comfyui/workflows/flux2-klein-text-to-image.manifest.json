{
  "schemaVersion": 2,
  "id": "flux2-klein-text-to-image",
  "label": "Flux 2 Klein Text to Image",
  "provider": "comfyui",
  "role": "image.generate",
  "description": "Prompt-based image generation using the bundled Flux 2 Klein workflow.",
  "workflowFile": "flux2-klein-text-to-image.workflow.json",
  "contract": {
    "inputs": {
      "prompt": {
        "type": "string",
        "required": true
      },
      "width": {
        "type": "integer",
        "required": false
      },
      "height": {
        "type": "integer",
        "required": false
      },
      "steps": {
        "type": "integer",
        "required": false
      },
      "seed": {
        "type": "integer",
        "required": false
      }
    },
    "outputs": {
      "images": {
        "type": "image-list",
        "required": true,
        "primary": "first"
      }
    }
  },
  "bindings": {
    "prompt": {
      "nodeId": "76",
      "nodeTitle": "noveltea.prompt",
      "classType": "PrimitiveStringMultiline",
      "inputName": "value",
      "valueType": "string",
      "selector": {
        "title": "noveltea.prompt",
        "classType": "PrimitiveStringMultiline",
        "inputName": "value"
      }
    },
    "width": {
      "nodeId": "75:68",
      "nodeTitle": "noveltea.width",
      "classType": "PrimitiveInt",
      "inputName": "value",
      "valueType": "integer",
      "selector": {
        "title": "noveltea.width",
        "classType": "PrimitiveInt",
        "inputName": "value"
      }
    },
    "height": {
      "nodeId": "75:69",
      "nodeTitle": "noveltea.height",
      "classType": "PrimitiveInt",
      "inputName": "value",
      "valueType": "integer",
      "selector": {
        "title": "noveltea.height",
        "classType": "PrimitiveInt",
        "inputName": "value"
      }
    },
    "seed": {
      "nodeId": "75:73",
      "nodeTitle": "noveltea.seed",
      "classType": "RandomNoise",
      "inputName": "noise_seed",
      "valueType": "integer",
      "selector": {
        "title": "noveltea.seed",
        "classType": "RandomNoise",
        "inputName": "noise_seed"
      }
    },
    "steps": {
      "nodeId": "75:62",
      "nodeTitle": "noveltea.steps",
      "classType": "Flux2Scheduler",
      "inputName": "steps",
      "valueType": "integer",
      "selector": {
        "title": "noveltea.steps",
        "classType": "Flux2Scheduler",
        "inputName": "steps"
      }
    },
    "filenamePrefix": {
      "nodeId": "9",
      "nodeTitle": "noveltea.output",
      "classType": "SaveImage",
      "inputName": "filename_prefix",
      "valueType": "string",
      "selector": {
        "title": "noveltea.output",
        "classType": "SaveImage",
        "inputName": "filename_prefix"
      }
    }
  },
  "defaults": {
    "width": 1024,
    "height": 1024,
    "steps": 20,
    "filenamePrefix": "NovelTea"
  },
  "outputNodeIds": [
    "9"
  ],
  "requiredNodeClasses": [
    "SaveImage",
    "PrimitiveStringMultiline",
    "KSamplerSelect",
    "Flux2Scheduler",
    "CFGGuider",
    "SamplerCustomAdvanced",
    "VAEDecode",
    "EmptyFlux2LatentImage",
    "CLIPTextEncode",
    "PrimitiveInt",
    "RandomNoise",
    "UNETLoader",
    "CLIPLoader",
    "VAELoader"
  ],
  "outputBindings": {
    "images": [
      {
        "nodeId": "9",
        "nodeTitle": "noveltea.output",
        "classType": "SaveImage",
        "inputName": "images",
        "valueType": "image-list",
        "primary": "first",
        "outputName": "images"
      }
    ]
  }
}
