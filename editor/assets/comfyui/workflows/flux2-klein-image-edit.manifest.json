{
  "schemaVersion": 2,
  "id": "flux2-klein-image-edit",
  "label": "Flux 2 Klein Image Edit",
  "provider": "comfyui",
  "role": "image.edit",
  "description": "Text-guided image editing using the bundled Flux 2 Klein workflow.",
  "workflowFile": "flux2-klein-image-edit.workflow.json",
  "contract": {
    "inputs": {
      "sourceImage": {
        "type": "image",
        "required": true
      },
      "prompt": {
        "type": "string",
        "required": true
      },
      "steps": {
        "type": "integer",
        "required": false
      },
      "seed": {
        "type": "integer",
        "required": false
      },
      "filenamePrefix": {
        "type": "string",
        "required": false,
        "editorField": "text",
        "defaultValue": "NovelTea"
      }
    },
    "outputs": {
      "images": {
        "type": "image-list",
        "required": true,
        "primary": "first"
      }
    }
  },
  "bindings": {
    "sourceImage": {
      "nodeId": "76",
      "nodeTitle": "noveltea.sourceImage",
      "classType": "LoadImage",
      "inputName": "image",
      "valueType": "image-upload-reference",
      "selector": {
        "title": "noveltea.sourceImage",
        "classType": "LoadImage",
        "inputName": "image"
      }
    },
    "prompt": {
      "nodeId": "75:74",
      "nodeTitle": "noveltea.prompt",
      "classType": "CLIPTextEncode",
      "inputName": "text",
      "valueType": "string",
      "selector": {
        "title": "noveltea.prompt",
        "classType": "CLIPTextEncode",
        "inputName": "text"
      }
    },
    "seed": {
      "nodeId": "75:73",
      "nodeTitle": "noveltea.seed",
      "classType": "RandomNoise",
      "inputName": "noise_seed",
      "valueType": "integer",
      "selector": {
        "title": "noveltea.seed",
        "classType": "RandomNoise",
        "inputName": "noise_seed"
      }
    },
    "steps": {
      "nodeId": "75:62",
      "nodeTitle": "noveltea.steps",
      "classType": "Flux2Scheduler",
      "inputName": "steps",
      "valueType": "integer",
      "selector": {
        "title": "noveltea.steps",
        "classType": "Flux2Scheduler",
        "inputName": "steps"
      }
    },
    "filenamePrefix": {
      "nodeId": "9",
      "nodeTitle": "noveltea.output",
      "classType": "SaveImage",
      "inputName": "filename_prefix",
      "valueType": "string",
      "selector": {
        "title": "noveltea.output",
        "classType": "SaveImage",
        "inputName": "filename_prefix"
      }
    }
  },
  "defaults": {
    "steps": 4,
    "filenamePrefix": "NovelTea"
  },
  "outputNodeIds": ["9"],
  "requiredNodeClasses": [
    "SaveImage",
    "LoadImage",
    "KSamplerSelect",
    "UNETLoader",
    "CLIPLoader",
    "VAELoader",
    "EmptyFlux2LatentImage",
    "ImageScaleToTotalPixels",
    "Flux2Scheduler",
    "CLIPTextEncode",
    "ConditioningZeroOut",
    "ReferenceLatent",
    "GetImageSize",
    "VAEEncode",
    "SamplerCustomAdvanced",
    "VAEDecode",
    "RandomNoise",
    "CFGGuider"
  ],
  "outputBindings": {
    "images": [
      {
        "nodeId": "9",
        "nodeTitle": "noveltea.output",
        "classType": "SaveImage",
        "inputName": "images",
        "valueType": "image-list",
        "primary": "first",
        "outputName": "images"
      }
    ]
  }
}
