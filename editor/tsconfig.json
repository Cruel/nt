{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "declaration": false,
    "outDir": "./dist",
    "paths": {
      "@/*": ["./src/renderer/*"]
    }
  },
  "include": [
    "src/**/*",
    "forge.config.ts",
    "vite.*.config.ts",
    "eslint.config.mjs",
    "vitest.config.ts",
    "forge.env.d.ts"
  ],
  "exclude": ["node_modules", "dist", "out", ".vite"]
}
