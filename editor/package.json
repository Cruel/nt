{
  "name": "noveltea-editor",
  "productName": "NovelTea Editor",
  "version": "1.0.0",
  "description": "NovelTea visual novel editor",
  "main": ".vite/build/main.js",
  "private": true,
  "packageManager": "pnpm@11.15.0",
  "scripts": {
    "start": "electron-forge start",
    "start:with-preview": "pnpm engine:preview:build && electron-forge start",
    "package": "electron-forge package",
    "package:smoke": "node scripts/run-package-smoke.mjs",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "project:compile": "vite-node scripts/compile-project.ts",
    "goldens:compiled-project": "vite-node scripts/generate-compiled-project-goldens.ts",
    "engine:preview:build": "node scripts/build-engine-preview.mjs",
    "engine:preview:clean": "node -e \"require('node:fs').rmSync('../build/web-debug/apps/sandbox',{recursive:true,force:true})\""
  },
  "keywords": [],
  "author": {
    "name": "Thomas Edvalson",
    "email": "machin3@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron-forge/shared-types": "7.11.2",
    "@electron/fuses": "^1.8.0",
    "@tailwindcss/vite": "^4.3.3",
    "@tanstack/router-plugin": "^1.168.22",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/node": "26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "43.1.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "lodash": "^4.18.1",
    "tailwindcss": "^4.3.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vite-node": "^6.0.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@codemirror/autocomplete": "6.20.3",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "6.12.4",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/lint": "6.9.7",
    "@codemirror/state": "6.7.1",
    "@codemirror/view": "6.43.6",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fsegurai/codemirror-theme-bundle": "^6.4.2",
    "@lezer/highlight": "1.2.3",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.18",
    "@tanstack/react-virtual": "^3.14.6",
    "@xyflow/react": "^12.11.2",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "electron-squirrel-startup": "^1.0.1",
    "fuse.js": "^7.5.0",
    "i18next": "^26.3.6",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.10",
    "react-resizable-panels": "^4.12.2",
    "resedit": "3.0.2",
    "sharp": "^0.35.3",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  }
}
