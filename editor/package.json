{
  "name": "noveltea-editor",
  "productName": "NovelTea Editor",
  "version": "1.0.0",
  "description": "NovelTea visual novel editor",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "start:with-preview": "pnpm engine:preview:build && electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "engine:preview:build": "node scripts/build-engine-preview.mjs",
    "engine:preview:clean": "node -e \"require('node:fs').rmSync('../build/web-debug/apps/sandbox',{recursive:true,force:true})\""
  },
  "keywords": [],
  "author": {
    "name": "Thomas Edvalson",
    "email": "machin3@gmail.com"
  },
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "@tailwindcss/vite": "^4.1.4",
    "@tanstack/router-plugin": "^1.114.10",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "42.4.0",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "jsdom": "^26.1.0",
    "lodash": "^4.17.21",
    "tailwindcss": "^4.1.4",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.31.0",
    "vite": "^6.3.2",
    "vitest": "^3.1.1"
  },
  "dependencies": {
    "@base-ui/react": "^1.1.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@fontsource-variable/dm-sans": "^5.2.5",
    "@fontsource/jetbrains-mono": "^5.2.5",
    "@tanstack/react-query": "^5.75.5",
    "@tanstack/react-router": "^1.114.10",
    "@tanstack/react-virtual": "^3.14.4",
    "@xyflow/react": "^12.11.1",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "electron-squirrel-startup": "^1.0.1",
    "fuse.js": "^7.4.2",
    "lucide-react": "^0.488.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-resizable-panels": "^4.12.0",
    "tailwind-merge": "^3.2.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.3"
  }
}
