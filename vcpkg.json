{
  "name": "noveltea",
  "version-string": "0.1.0",
  "dependencies": [
    "bgfx",
    {
      "name": "rmlui",
      "features": [
        "freetype"
      ]
    },
    "sdl3",
    "miniaudio",
    {
      "name": "imgui",
      "features": [
        "sdl3-binding",
        "docking-experimental",
        "freetype"
      ]
    },
    "harfbuzz"
  ],
  "features": {
    "shader-tools": {
      "description": "Install bgfx shader compiler tools for regenerating shader headers.",
      "dependencies": [
        {
          "name": "bgfx",
          "features": [
            "tools"
          ]
        }
      ]
    }
  }
}