{
    "version": 6,
    "configurePresets": [
        {
            "name": "linux-debug",
            "displayName": "Linux Debug",
            "description": "Debug build for Linux desktop using vcpkg",
            "binaryDir": "${sourceDir}/build/linux-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
                "VCPKG_MANIFEST_DIR": "${sourceDir}",
                "VCPKG_MANIFEST_FEATURES": "shader-tools;tests",
                "VCPKG_INSTALLED_DIR": "${sourceDir}/build/linux-debug/vcpkg_installed",
                "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/cmake/vcpkg-triplets",
                "VCPKG_TARGET_TRIPLET": "x64-linux-noveltea",
                "VCPKG_HOST_TRIPLET": "x64-linux",
                "NOVELTEA_ENABLE_THREADS": "ON",
                "NOVELTEA_JOB_WORKER_COUNT": "0"
            }
        },
        {
            "name": "linux-debug-no-threads",
            "displayName": "Linux Debug (No Threads)",
            "description": "Native cooperative-executor verification build",
            "inherits": "linux-debug",
            "binaryDir": "${sourceDir}/build/linux-debug-no-threads",
            "cacheVariables": {
                "VCPKG_INSTALLED_DIR": "${sourceDir}/build/linux-debug-no-threads/vcpkg_installed",
                "NOVELTEA_ENABLE_THREADS": "OFF",
                "NOVELTEA_JOB_WORKER_COUNT": "0"
            }
        },
        {
            "name": "linux-debug-editor-profiler",
            "displayName": "Linux Debug Editor Asset Profiler",
            "description": "Native engine profiler test build",
            "inherits": "linux-debug",
            "binaryDir": "${sourceDir}/build/linux-debug-editor-profiler",
            "cacheVariables": {
                "VCPKG_INSTALLED_DIR": "${sourceDir}/build/linux-debug-editor-profiler/vcpkg_installed",
                "NOVELTEA_ENABLE_EDITOR_ASSET_PROFILER": "ON"
            }
        },
        {
            "name": "linux-debug-local-rmlui-bgfx",
            "displayName": "Linux Debug + Local rmlui-bgfx",
            "description": "Debug build for tandem NovelTea/rmlui-bgfx development",
            "inherits": "linux-debug",
            "cacheVariables": {
                "NOVELTEA_USE_LOCAL_RMLUI_BGFX": "ON",
                "NOVELTEA_LOCAL_RMLUI_BGFX_DIR": "${sourceDir}/rmlui-bgfx"
            }
        },
        {
            "name": "linux-sanitize",
            "displayName": "Linux ASan + UBSan",
            "description": "Native robustness build with parser fuzz smoke targets",
            "inherits": "linux-debug",
            "binaryDir": "${sourceDir}/build/linux-sanitize",
            "cacheVariables": {
                "VCPKG_INSTALLED_DIR": "${sourceDir}/build/linux-sanitize/vcpkg_installed",
                "NOVELTEA_ENABLE_SANITIZERS": "ON",
                "NOVELTEA_BUILD_FUZZERS": "ON",
                "NOVELTEA_ENABLE_DEVTOOLS": "OFF"
            }
        },
        {
            "name": "linux-release",
            "displayName": "Linux Release",
            "description": "Release build for Linux desktop",
            "binaryDir": "${sourceDir}/build/linux-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
                "VCPKG_MANIFEST_DIR": "${sourceDir}",
                "VCPKG_INSTALLED_DIR": "${sourceDir}/build/linux-release/vcpkg_installed",
                "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/cmake/vcpkg-triplets",
                "VCPKG_TARGET_TRIPLET": "x64-linux-noveltea",
                "VCPKG_HOST_TRIPLET": "x64-linux",
                "NOVELTEA_ENABLE_THREADS": "ON",
                "NOVELTEA_JOB_WORKER_COUNT": "0",
                "NOVELTEA_ENABLE_RENDER_PERF": "OFF",
                "NOVELTEA_ENABLE_DEVTOOLS": "OFF",
                "NOVELTEA_ENABLE_EDITOR_ASSET_PROFILER": "OFF"
            }
        },
        {
            "name": "linux-release-editor-profiler",
            "displayName": "Linux Release Editor Asset Profiler",
            "description": "Optimized native asset-profiler stress and serialization verification build",
            "inherits": "linux-release",
            "binaryDir": "${sourceDir}/build/linux-release-editor-profiler",
            "cacheVariables": {
                "VCPKG_MANIFEST_FEATURES": "shader-tools;tests",
                "VCPKG_INSTALLED_DIR": "${sourceDir}/build/linux-release-editor-profiler/vcpkg_installed",
                "NOVELTEA_ENABLE_EDITOR_ASSET_PROFILER": "ON"
            }
        },
        {
            "name": "windows-release",
            "displayName": "Windows Release",
            "description": "Release build for Windows desktop using static vcpkg libraries",
            "binaryDir": "${sourceDir}/build/windows-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
                "VCPKG_MANIFEST_DIR": "${sourceDir}",
                "VCPKG_INSTALLED_DIR": "${sourceDir}/build/windows-release/vcpkg_installed",
                "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/cmake/vcpkg-triplets",
                "VCPKG_TARGET_TRIPLET": "x64-windows-static-noveltea",
                "VCPKG_HOST_TRIPLET": "x64-windows",
                "NOVELTEA_ENABLE_THREADS": "ON",
                "NOVELTEA_JOB_WORKER_COUNT": "0",
                "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded",
                "NOVELTEA_ENABLE_RENDER_PERF": "OFF",
                "NOVELTEA_ENABLE_DEVTOOLS": "OFF",
                "NOVELTEA_ENABLE_EDITOR_ASSET_PROFILER": "OFF"
            }
        },
        {
            "name": "macos-release",
            "displayName": "macOS Release",
            "description": "Release build for macOS desktop",
            "binaryDir": "${sourceDir}/build/macos-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
                "VCPKG_MANIFEST_DIR": "${sourceDir}",
                "VCPKG_INSTALLED_DIR": "${sourceDir}/build/macos-release/vcpkg_installed",
                "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/cmake/vcpkg-triplets",
                "VCPKG_TARGET_TRIPLET": "arm64-osx-noveltea",
                "VCPKG_HOST_TRIPLET": "arm64-osx",
                "NOVELTEA_ENABLE_THREADS": "ON",
                "NOVELTEA_JOB_WORKER_COUNT": "0",
                "NOVELTEA_ENABLE_RENDER_PERF": "OFF",
                "NOVELTEA_ENABLE_DEVTOOLS": "OFF",
                "NOVELTEA_ENABLE_EDITOR_ASSET_PROFILER": "OFF"
            }
        },
        {
            "name": "web-debug",
            "displayName": "Web Debug (Emscripten)",
            "description": "Debug build for Web using Emscripten",
            "binaryDir": "${sourceDir}/build/web-debug",
            "toolchainFile": "${sourceDir}/cmake/toolchains/emscripten.cmake",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BUILD_TESTING": "OFF",
                "NOVELTEA_ENABLE_THREADS": "ON",
                "NOVELTEA_JOB_WORKER_COUNT": "1"
            }
        },
        {
            "name": "web-debug-no-threads",
            "displayName": "Web Debug (No Threads)",
            "description": "Debug Web compatibility build without pthread/shared memory",
            "inherits": "web-debug",
            "binaryDir": "${sourceDir}/build/web-debug-no-threads",
            "cacheVariables": {
                "NOVELTEA_ENABLE_THREADS": "OFF",
                "NOVELTEA_JOB_WORKER_COUNT": "0"
            }
        },
        {
            "name": "web-debug-local-rmlui-bgfx",
            "displayName": "Web Debug + Local rmlui-bgfx",
            "description": "Debug Web build for tandem NovelTea/rmlui-bgfx development",
            "inherits": "web-debug",
            "cacheVariables": {
                "NOVELTEA_USE_LOCAL_RMLUI_BGFX": "ON",
                "NOVELTEA_LOCAL_RMLUI_BGFX_DIR": "${sourceDir}/rmlui-bgfx"
            }
        },
        {
            "name": "web-release",
            "displayName": "Web Release (Emscripten)",
            "description": "Release build for Web using Emscripten with -Oz -flto",
            "binaryDir": "${sourceDir}/build/web-release",
            "toolchainFile": "${sourceDir}/cmake/toolchains/emscripten.cmake",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "MinSizeRel",
                "BUILD_TESTING": "OFF",
                "NOVELTEA_ENABLE_RENDER_PERF": "OFF",
                "NOVELTEA_ENABLE_DEVTOOLS": "OFF",
                "NOVELTEA_ENABLE_EDITOR_ASSET_PROFILER": "OFF",
                "NOVELTEA_ENABLE_THREADS": "ON",
                "NOVELTEA_JOB_WORKER_COUNT": "1"
            }
        },
        {
            "name": "web-release-no-threads",
            "displayName": "Web Release (No Threads)",
            "description": "Release Web compatibility build without pthread/shared memory",
            "inherits": "web-release",
            "binaryDir": "${sourceDir}/build/web-release-no-threads",
            "cacheVariables": {
                "NOVELTEA_ENABLE_THREADS": "OFF",
                "NOVELTEA_JOB_WORKER_COUNT": "0"
            }
        },
        {
            "name": "web-editor-preview",
            "displayName": "Web Editor Preview",
            "description": "Optimized editor Play preview with asset profiler support",
            "inherits": "web-release",
            "binaryDir": "${sourceDir}/build/web-editor-preview",
            "cacheVariables": {
                "NOVELTEA_ENABLE_EDITOR_ASSET_PROFILER": "ON",
                "NOVELTEA_BUILD_SANDBOX": "ON",
                "NOVELTEA_BUILD_PLAYER": "OFF",
                "NOVELTEA_ENABLE_DEVTOOLS": "OFF",
                "NOVELTEA_WEB_SHELL_FILE": "${sourceDir}/web/widget.html"
            }
        },
        {
            "name": "web-profile",
            "displayName": "Web Profile (Emscripten)",
            "description": "Optimized Web build with RmlUi/bgfx render performance counters enabled",
            "binaryDir": "${sourceDir}/build/web-profile",
            "toolchainFile": "${sourceDir}/cmake/toolchains/emscripten.cmake",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "MinSizeRel",
                "BUILD_TESTING": "OFF",
                "NOVELTEA_ENABLE_RENDER_PERF": "ON",
                "NOVELTEA_ENABLE_THREADS": "ON",
                "NOVELTEA_JOB_WORKER_COUNT": "1"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "linux-debug",
            "configurePreset": "linux-debug"
        },
        {
            "name": "linux-debug-no-threads",
            "configurePreset": "linux-debug-no-threads"
        },
        {
            "name": "linux-debug-editor-profiler",
            "configurePreset": "linux-debug-editor-profiler"
        },
        {
            "name": "linux-debug-local-rmlui-bgfx",
            "configurePreset": "linux-debug-local-rmlui-bgfx"
        },
        {
            "name": "linux-sanitize",
            "configurePreset": "linux-sanitize"
        },
        {
            "name": "linux-release",
            "configurePreset": "linux-release"
        },
        {
            "name": "linux-release-editor-profiler",
            "configurePreset": "linux-release-editor-profiler"
        },
        {
            "name": "windows-release",
            "configurePreset": "windows-release"
        },
        {
            "name": "macos-release",
            "configurePreset": "macos-release"
        },
        {
            "name": "web-debug",
            "configurePreset": "web-debug"
        },
        {
            "name": "web-debug-no-threads",
            "configurePreset": "web-debug-no-threads"
        },
        {
            "name": "web-debug-local-rmlui-bgfx",
            "configurePreset": "web-debug-local-rmlui-bgfx"
        },
        {
            "name": "web-release",
            "configurePreset": "web-release"
        },
        {
            "name": "web-release-no-threads",
            "configurePreset": "web-release-no-threads"
        },
        {
            "name": "web-editor-preview",
            "configurePreset": "web-editor-preview"
        },
        {
            "name": "web-profile",
            "configurePreset": "web-profile"
        }
    ]
}
