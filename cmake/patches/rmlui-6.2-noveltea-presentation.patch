 	return dimensions;
 }
 
+void Context::SetMediaQueryDimensions(const Vector2i _dimensions)
+{
+	const Vector2i previous_dimensions = GetMediaQueryDimensions();
+	media_query_dimensions = _dimensions;
+	has_media_query_dimensions = true;
+
+	if (previous_dimensions != GetMediaQueryDimensions())
+		DirtyMediaQueries();
+}
+
+void Context::ClearMediaQueryDimensions()
+{
+	if (!has_media_query_dimensions)
+		return;
+
+	const Vector2i previous_dimensions = GetMediaQueryDimensions();
+	has_media_query_dimensions = false;
+
+	if (previous_dimensions != GetMediaQueryDimensions())
+		DirtyMediaQueries();
+}
+
+Vector2i Context::GetMediaQueryDimensions() const
+{
+	return has_media_query_dimensions ? media_query_dimensions : dimensions;
+}
